@prefix kpi: <http://bimerr.iot.linkeddata.es/def/key-performance-indicator#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix core: <https://saref.etsi.org/core/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix brick: <https://brickschema.org/schema/Brick#> .
@prefix ncrem: <http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#> .
@prefix shacl: <http://www.w3.org/ns/shacl#> .
@prefix s4city: <https://saref.etsi.org/saref4city/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix saref4ener: <https://saref.etsi.org/saref4ener/> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix schema: <https://schema.org/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix s4agri: <https://saref.etsi.org/saref4agri/> .
@prefix s4bldg: <https://saref.etsi.org/saref4bldg/> .
@prefix building: <http://bimerr.iot.linkeddata.es/def/building#> .
@prefix mat: <http://bimerr.iot.linkeddata.es/def/material-properties#> .
@prefix weat: <https://bimerr.iot.linkeddata.es/def/weather#> .
@prefix gtfs: <http://vocab.gtfs.org/terms#> .
@prefix brickref: <https://brickschema.org/schema/Brick/ref#> .
@prefix saref: <https://w3id.org/saref#> .
@base <http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#> .

<http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#> rdf:type owl:Ontology ;
                                                                         <http://purl.org/dc/elements/1.1/title> "Neighborhood Construction, Renovation & Energy Management (NCREM) Ontology" ;
                                                                         dcterms:contributor "Nikolaos Kampelis" ,
                                                                                            "Dionysia Kolokotsa" ;
                                                                         dcterms:creator "Filippos Lygerakis, Environmental Engineer, MSc, Technical University of Crete (TUC)" ;
                                                                         dcterms:description "An ontology for representing neighborhoods in the context of building construction, renovation projects, and energy management. It defines concepts for buildings, renovations, energy systems, and related Key Performance Indicators (KPIs), integrating terms from Brick Schema and SAREF for smart city applications." ;
                                                                         dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
                                                                         dcterms:issued "2026-04-03"^^xsd:date ;
                                                                         owl:versionIRI <http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology/1.1> ;
                                                                         owl:imports <https://brickschema.org/schema/1.3/Brick#> ,
                                                                                     <https://saref.etsi.org/core/> ,
                                                                                     <https://saref.etsi.org/saref4city/> ,
                                                                                     <https://saref.etsi.org/saref4ener/> ,
                                                                                     <https://saref.etsi.org/saref4agri/> ,
                                                                                     <http://www.w3.org/ns/ssn/> ,
                                                                                     <http://www.w3.org/ns/sosa/> ;
                                                                         owl:versionInfo "1.1" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/contributor
dcterms:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
dcterms:publisher rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasTimeseriesID
ncrem:hasTimeseriesID rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#and
shacl:and rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#class
shacl:class rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#message
shacl:message rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#property
shacl:property rdf:type owl:AnnotationProperty .


###  http://www.w3.org/ns/shacl#rule
shacl:rule rdf:type owl:AnnotationProperty .


###  https://brickschema.org/schema/Brick#storedAt
brick:storedAt rdf:type owl:AnnotationProperty .

#################################################################
#    Object Properties
#################################################################

###  http://bimerr.iot.linkeddata.es/def/key-performance-indicator#relatedKPI
kpi:relatedKPI rdf:type owl:ObjectProperty ;
               rdfs:domain kpi:Scenario ;
               rdfs:range <https://saref.etsi.org/saref4city/KeyPerformanceIndicator> ;
               rdfs:label "related Kpi"@en ;
               skos:definition "relates an entity with specific kpi definitions."@en .


###  http://bimerr.iot.linkeddata.es/def/key-performance-indicator#relatedKPIValue
kpi:relatedKPIValue rdf:type owl:ObjectProperty ;
                    rdfs:label "related Kpi value"@en ;
                    skos:definition "Relates an entity with specific kpi values."@en .


###  http://bimerr.iot.linkeddata.es/def/key-performance-indicator#relatedProject
kpi:relatedProject rdf:type owl:ObjectProperty ;
                   rdfs:domain kpi:Scenario ;
                   rdfs:label "related project"@en ;
                   skos:definition "Relates an entity with a project."@en .


###  http://bimerr.iot.linkeddata.es/def/key-performance-indicator#relatedScenario
kpi:relatedScenario rdf:type owl:ObjectProperty ;
                    rdfs:range kpi:Scenario ;
                    rdfs:label "related scenario"@en ;
                    skos:definition "Relates an entity with a renovation scenario."@en .


###  http://bimerr.iot.linkeddata.es/def/material-properties#hasMaterial
<http://bimerr.iot.linkeddata.es/def/material-properties#hasMaterial> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf owl:topObjectProperty ;
                                                                      skos:definition "Relation between a construction component (Layer, profile, constituent) and the materials that define them." .


###  http://bimerr.iot.linkeddata.es/def/material-properties#hasMaterialLayer
<http://bimerr.iot.linkeddata.es/def/material-properties#hasMaterialLayer> rdf:type owl:ObjectProperty ;
                                                                           rdfs:subPropertyOf owl:topObjectProperty ;
                                                                           skos:definition "A relation between a layer set and the specific material layers." .


###  http://purl.org/dc/terms/hasFormat
dcterms:hasFormat rdf:type owl:ObjectProperty .


###  http://purl.org/vocab/cpsv#provides
<http://purl.org/vocab/cpsv#provides> rdf:type owl:ObjectProperty ;
                                      skos:definition "The provides property links an Agent to a Public Service for which it is responsible. Whether it provides the service directly or outsources it is not relevant, the Agent that provides the service is the one that is ultimately responsible for its provision" .


###  http://purl.org/vocab/cpsv#uses
<http://purl.org/vocab/cpsv#uses> rdf:type owl:ObjectProperty ;
                                  skos:definition "The uses property links an Agent to a Public Service in which it plays the specific role of user, meaning that it provides the input and receives the output but does not play any direct role in providing the service. This will typically be an individual citizen or an outside organisation." .


###  http://vocab.gtfs.org/terms#parentStation
<http://vocab.gtfs.org/terms#parentStation> rdf:type owl:ObjectProperty .


###  http://vocab.gtfs.org/terms#route
<http://vocab.gtfs.org/terms#route> rdf:type owl:ObjectProperty .


###  http://vocab.gtfs.org/terms#stop
<http://vocab.gtfs.org/terms#stop> rdf:type owl:ObjectProperty ;
                                   skos:definition "Indicates that this has a certain stop." .


###  http://vocab.gtfs.org/terms#trip
<http://vocab.gtfs.org/terms#trip> rdf:type owl:ObjectProperty ;
                                   rdfs:comment "Indicates that this is part of a certain gtfs:Trip" .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasAgent
ncrem:hasAgent rdf:type owl:ObjectProperty ;
               rdfs:range <http://xmlns.com/foaf/0.1/Agent> ;
               skos:definition "Indicates that the subject involves or is carried out by the specified agent" .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasDependency
ncrem:hasDependency rdf:type owl:ObjectProperty ;
                    skos:definition "Indicates that the subject depends on the object to be completed, initiated, or properly evaluated." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasDuration
ncrem:hasDuration rdf:type owl:ObjectProperty ;
                  skos:definition "Links a process, task, or event to its associated duration." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasImage
ncrem:hasImage rdf:type owl:ObjectProperty ;
               skos:definition "Links an entity to an image representing or describing it." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasLayer
ncrem:hasLayer rdf:type owl:ObjectProperty ;
               skos:definition "Relates a construction element, component, or material assembly to its individual layer(s)." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasParkingSpace
ncrem:hasParkingSpace rdf:type owl:ObjectProperty ;
                      rdfs:comment "links a ParkingFacility to a ParkingSpace that it includes." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasSensor
ncrem:hasSensor rdf:type owl:ObjectProperty ;
                rdfs:range brick:Sensor ;
                skos:definition "Indicates that a given system, component, or space is equipped with a sensor responsible for monitoring or measuring specific environmental or operational parameters." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasSetpoint
ncrem:hasSetpoint rdf:type owl:ObjectProperty ;
                  rdfs:range ncrem:Setpoint ;
                  skos:definition "Relates a controllable system, device, or component to a setpoint that defines its intended target value for operation" .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasStation
ncrem:hasStation rdf:type owl:ObjectProperty ;
                 rdfs:comment "Links a shared mobility service or network to its stations." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasSupplier
ncrem:hasSupplier rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasWeatherFileProperty
ncrem:hasWeatherFileProperty rdf:type owl:ObjectProperty ;
                             rdfs:range ncrem:Weather_File_Properties ;
                             skos:definition "Relates a weather file to a specific environmental property it contains" .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#locatedOnStreet
ncrem:locatedOnStreet rdf:type owl:ObjectProperty ;
                      rdfs:comment "Links a pedestrian feature (Path, Crosswalk) to a street (could use a schema:Route or ncrem:Street class)." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#monitors_Segment
ncrem:monitors_Segment rdf:type owl:ObjectProperty ;
                       rdfs:domain brick:Sensor ;
                       rdfs:comment "Relates a Sensor to the RoadSegment it monitors." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#servesStop
ncrem:servesStop rdf:type owl:ObjectProperty ;
                 rdfs:comment "Indicates a gtfs:Route serves a particular Stop (i.e., the stop is on that routeâ€™s itinerary)." .


###  http://www.w3.org/ns/sosa/hasFeatureOfInterest
<http://www.w3.org/ns/sosa/hasFeatureOfInterest> rdf:type owl:ObjectProperty ;
                                                 rdfs:comment "has feature of interest - A relation between an Observation and the entity whose quality was observed, or between an Actuation and the entity whose property was modified, or between an act of Sampling and the entity that was sampled." .


###  http://www.w3.org/ns/sosa/madeBySensor
<http://www.w3.org/ns/sosa/madeBySensor> rdf:type owl:ObjectProperty ;
                                         rdfs:comment "made by Sensor - Relation between an Observation and the Sensor which made the Observations." .


###  http://www.w3.org/ns/sosa/observedProperty
<http://www.w3.org/ns/sosa/observedProperty> rdf:type owl:ObjectProperty ;
                                             rdfs:range core:Property ;
                                             rdfs:comment "observed property - Relation linking an Observation to the property that was observed. The ObservableProperty should be a property of the FeatureOfInterest (linked by hasFeatureOfInterest) of this Observation." .


###  https://brickschema.org/schema/Brick#hasLocation
brick:hasLocation rdf:type owl:ObjectProperty ;
                  rdfs:range brick:Location ;
                  skos:definition "Used to associate an entity (like equipment, sensors, or zones) with its physical or logical location within a building. This can be a room, floor, zone, or any other defined space." .


###  https://brickschema.org/schema/Brick#hasParameter
brick:hasParameter rdf:type owl:ObjectProperty ;
                   skos:definition "Links an entity to a parameter that defines certain operational or configuration aspects of that entity." .


###  https://brickschema.org/schema/Brick#hasPart
brick:hasPart rdf:type owl:ObjectProperty ;
              rdfs:range brick:Equipment ;
              skos:definition "The subject is composed in part of the entity given by the object" .


###  https://brickschema.org/schema/Brick#hasTime
brick:hasTime rdf:type owl:ObjectProperty ;
              rdfs:range ncrem:Time ;
              skos:definition "Indicates the relationship between a product, material, or component and the organization or agent that supplies it." .


###  https://brickschema.org/schema/Brick#hasTimeseriesId
brick:hasTimeseriesId rdf:type owl:ObjectProperty ;
                      skos:definition "The unique identifier (primary key) for this TimeseriesReference in some database" .


###  https://brickschema.org/schema/Brick#feeds
brick:feeds rdf:type owl:ObjectProperty ;
            skos:definition "Indicates that the subject is arranged upstream of the object, implying that some media flows from the subject into the object." .


###  https://brickschema.org/schema/Brick#hasPoint
brick:hasPoint rdf:type owl:ObjectProperty ;
               skos:definition "The subject has a source of telemetry identified by the object. In some systems the source of telemetry may be represented as a digital/analog input/output point" .


###  https://brickschema.org/schema/Brick#hasUnit
brick:hasUnit rdf:type owl:ObjectProperty ;
              rdfs:range qudt:Unit .


###  https://brickschema.org/schema/Brick#isLocationOf
brick:isLocationOf rdf:type owl:ObjectProperty ;
                   skos:definition "Subject is the physical location encapsulating the object" .


###  https://brickschema.org/schema/Brick#isPointOf
brick:isPointOf rdf:type owl:ObjectProperty ;
                rdfs:domain brick:Sensor ;
                rdfs:range brick:Electrical_Equipment ,
                           brick:Location .


###  https://brickschema.org/schema/Brick#meters
brick:meters rdf:type owl:ObjectProperty ;
             skos:definition "Indicates the entity whose consumption/production of some substance is measured by this meter" .


###  https://saref.etsi.org/core/hasProperty
core:hasProperty rdf:type owl:ObjectProperty .


###  https://saref.etsi.org/core/hasValue
core:hasValue rdf:type owl:DatatypeProperty ;
              skos:definition "Value of a property expressed as an RDF literal. Note that, even if decimal values are expected, values could use other datatypes." .


###  https://saref.etsi.org/saref4city/hasKPI
s4city:hasKPI rdf:type owl:ObjectProperty ;
              rdfs:range <https://saref.etsi.org/saref4city/KeyPerformanceIndicator> .


###  https://saref.etsi.org/saref4ener/hasEnergy
saref4ener:hasEnergy rdf:type owl:ObjectProperty ;
                     rdfs:range core:Energy .


###  https://schema.org/address
<https://schema.org/address> rdf:type owl:ObjectProperty ;
                             rdfs:comment "Physical address of the item." .


###  https://schema.org/geo
<https://schema.org/geo> rdf:type owl:ObjectProperty ;
                         rdfs:domain brick:Location ;
                         rdfs:comment "The geo coordinates of the place." .


###  https://schema.org/provider
<https://schema.org/provider> rdf:type owl:ObjectProperty ;
                              rdfs:domain brick:Location .


#################################################################
#    Data properties
#################################################################

###  http://bimerr.iot.linkeddata.es/def/key-performance-indicator#description
kpi:description rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#availableSpaces
ncrem:availableSpaces rdf:type owl:DatatypeProperty ;
                      rdfs:range xsd:int ;
                      skos:definition "Current number of free/unoccupied parking spots available in the facility." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#averageSpeed
ncrem:averageSpeed rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:double ;
                   rdfs:comment "Average speed of vehicles, typically in kilometers per hour, on a road segment." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#capacity
ncrem:capacity rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:int ;
               skos:definition "Total number of parking spaces in the facility." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#congestionLevel
ncrem:congestionLevel rdf:type owl:DatatypeProperty ;
                      rdfs:range xsd:string ;
                      rdfs:comment "A qualitative or quantitative indicator of congestion" .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#hasBikeCapacity
ncrem:hasBikeCapacity rdf:type owl:DatatypeProperty ;
                      rdfs:comment "number of bike parking spots" .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#occupancyRate
ncrem:occupancyRate rdf:type owl:DatatypeProperty ;
                    rdfs:range xsd:double ;
                    skos:definition "The percentage of occupancy." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#occupiedSpaces
ncrem:occupiedSpaces rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:int ;
                     skos:definition "Current number of occupied spots." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#vehicleCount
ncrem:vehicleCount rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:int ;
                   rdfs:comment "the number of vehicles observed in a time interval at a location (traffic volume count)." .


###  http://www.w3.org/ns/sosa/resultTime
<http://www.w3.org/ns/sosa/resultTime> rdf:type owl:DatatypeProperty ;
                                       rdfs:range xsd:dateTime ;
                                       rdfs:comment "result time - The result time is the instant of time when the Observation, Actuation or Sampling activity was completed." .


###  https://brickschema.org/schema/Brick/ref#hasTimeseriesId
<https://brickschema.org/schema/Brick/ref#hasTimeseriesId> rdf:type owl:DatatypeProperty ;
                                                           rdfs:domain brick:Meter ,
                                                                       brick:Sensor ;
                                                           rdfs:range xsd:string ;
                                                           rdfs:label "hasTimeseriesId" ;
                                                           skos:definition "The unique identifier (primary key) for this TimeseriesReference in some database"@en .


###  https://brickschema.org/schema/Brick/ref#storedAt
<https://brickschema.org/schema/Brick/ref#storedAt> rdf:type owl:DatatypeProperty ;
                                                    rdfs:range xsd:anyURI ;
                                                    rdfs:label "storedAt" ;
                                                    skos:definition "A reference to where the data for this TimeseriesReference is stored"@en .



#################################################################
#    Classes
#################################################################

###  http://bimerr.iot.linkeddata.es/def/building#BuildingElement
<http://bimerr.iot.linkeddata.es/def/building#BuildingElement> rdf:type owl:Class ;
                                                               rdfs:subClassOf <http://bimerr.iot.linkeddata.es/def/building#Element> ;
                                                               rdfs:comment "The building element comprises all elements that are primarily part of the construction of a building, i.e., its structural and space separating system. Building elements are all physically existent and tangible things."@en ;
                                                               rdfs:label "Building Element" ;
                                                               rdfs:seeAlso "http://standards.buildingsmart.org/IFC/DEV/IFC4_1/OWL#IfcBuildingElement" .


###  http://bimerr.iot.linkeddata.es/def/building#Door
<http://bimerr.iot.linkeddata.es/def/building#Door> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://bimerr.iot.linkeddata.es/def/building#BuildingElement> ;
                                                    rdfs:comment "The door is a building element that is predominately used to provide controlled access for people and goods. It includes constructions with hinged, pivoted, sliding, and additionally revolving and folding operations. A door consists of a lining and one or several panels."@en ;
                                                    rdfs:label "Door" ;
                                                    rdfs:seeAlso "http://standards.buildingsmart.org/IFC/DEV/IFC4_1/OWL#IfcDoor" .


###  http://bimerr.iot.linkeddata.es/def/building#Element
<http://bimerr.iot.linkeddata.es/def/building#Element> rdf:type owl:Class ;
                                                       skos:definition "An element is a generalization of all components that make up an AEC product." .


###  http://bimerr.iot.linkeddata.es/def/building#Roof
<http://bimerr.iot.linkeddata.es/def/building#Roof> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://bimerr.iot.linkeddata.es/def/building#BuildingElement> ;
                                                    rdfs:comment "A roof is the covering of the top part of a building, it protects the building against the effects of wheather."@en ;
                                                    rdfs:label "Roof" ;
                                                    rdfs:seeAlso "http://standards.buildingsmart.org/IFC/DEV/IFC4_1/OWL#IfcRoof" .


###  http://bimerr.iot.linkeddata.es/def/building#Slab
<http://bimerr.iot.linkeddata.es/def/building#Slab> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://bimerr.iot.linkeddata.es/def/building#BuildingElement> ;
                                                    rdfs:comment "A slab is a component of the construction that normally encloses a space vertically. The slab may provide the lower support (floor) or upper construction (roof slab) in any space in a building."@en ;
                                                    rdfs:label "Slab" ;
                                                    rdfs:seeAlso "http://standards.buildingsmart.org/IFC/DEV/IFC4_1/OWL#IfcSlab" .


###  http://bimerr.iot.linkeddata.es/def/building#Wall
<http://bimerr.iot.linkeddata.es/def/building#Wall> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://bimerr.iot.linkeddata.es/def/building#BuildingElement> ;
                                                    rdfs:comment "The wall represents a vertical construction that bounds or subdivides spaces. Wall are usually vertical, or nearly vertical, planar elements, often designed to bear structural loads. A wall is however not required to be load bearing."@en ;
                                                    rdfs:label "Wall" ;
                                                    rdfs:seeAlso "http://standards.buildingsmart.org/IFC/DEV/IFC4_1/OWL#IfcWall" .


###  http://bimerr.iot.linkeddata.es/def/building#Window
<http://bimerr.iot.linkeddata.es/def/building#Window> rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://bimerr.iot.linkeddata.es/def/building#BuildingElement> ;
                                                      rdfs:comment "The window is a building element that is predominately used to provide natural light and fresh air. It includes vertical opening but also horizontal opening such as skylights or light domes. It includes constructions with swinging, pivoting, sliding, or revolving panels and fixed panels. A window consists of a lining and one or several panels."@en ;
                                                      rdfs:label "Window" ;
                                                      rdfs:seeAlso "http://standards.buildingsmart.org/IFC/DEV/IFC4_1/OWL#IfcWindow" .


