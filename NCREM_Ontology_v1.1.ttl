                            rdfs:subClassOf ncrem:Setpoint ;
                            skos:definition "Target temperature maintained by the cooling system in a specific zone." .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#Zone_Energy
ncrem:Zone_Energy rdf:type owl:Class ;
                  rdfs:subClassOf core:Energy ;
