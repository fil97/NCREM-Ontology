###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#Vegetation
ncrem:Vegetation rdf:type owl:Class ;
                 rdfs:subClassOf ncrem:HEGR_Layers ;
                 skos:definition "The living plant layer that offers environmental benefits such as thermal insulation, urban heat island mitigation, and stormwater management." .


