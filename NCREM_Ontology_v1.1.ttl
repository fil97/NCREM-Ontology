###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#Price
ncrem:Price rdf:type owl:Class ;
            rdfs:subClassOf core:Property ;
            skos:definition "A value representing the monetary cost of a product, service, or energy quantity, often expressed in â‚¬/kWh, â‚¬/unit, or total cost." .


