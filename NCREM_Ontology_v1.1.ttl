                                                       skos:definition "Indicates if the file that have been analyzed is in format EPW from the Energy Plus Weather or the Climate OneBuilding.Weather services." .


###  https://bimerr.iot.linkeddata.es/def/weather#Ground
<https://bimerr.iot.linkeddata.es/def/weather#Ground> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://bimerr.iot.linkeddata.es/def/weather#WeatherProperty> ;
                                                      rdfs:comment "Ground properties where the measures are made."@en ;
                                                      rdfs:label "Ground"@en .


###  https://bimerr.iot.linkeddata.es/def/weather#Humidity
<https://bimerr.iot.linkeddata.es/def/weather#Humidity> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://bimerr.iot.linkeddata.es/def/weather#WeatherProperty> ;
                                                        skos:definition "Measure of the amount of moisture in the air. It tells you how comfortable it is to be outside, and if there is enough moisture to create clouds and rain." .


###  https://bimerr.iot.linkeddata.es/def/weather#Illuminance
<https://bimerr.iot.linkeddata.es/def/weather#Illuminance> rdf:type owl:Class ;
                                                           rdfs:subClassOf <https://bimerr.iot.linkeddata.es/def/weather#WeatherProperty> ;
                                                           rdfs:comment "The total luminous flux incident on a surface, per unit area. It is a measure of how much the incident light illuminates the surface, wavelength-weighted by the luminosity function to correlate with human brightness perception." ;
                                                           rdfs:label "Illuminance"@en .


###  https://bimerr.iot.linkeddata.es/def/weather#Precipitation
<https://bimerr.iot.linkeddata.es/def/weather#Precipitation> rdf:type owl:Class ;
                                                             rdfs:subClassOf <https://bimerr.iot.linkeddata.es/def/weather#AtmosphericPhenomenon> ;
                                                             rdfs:comment "Any product of the condensation of atmospheric water vapour that falls under gravity from clouds. The main forms of precipitation include drizzle, rain, sleet, snow, ice pellets, graupel and hail." ;
                                                             rdfs:label "Precipitation"@en .


###  https://bimerr.iot.linkeddata.es/def/weather#Pressure
<https://bimerr.iot.linkeddata.es/def/weather#Pressure> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://bimerr.iot.linkeddata.es/def/weather#WeatherProperty> ;
                                                        rdfs:comment "The force exerted over a given area or object, either because of gravity pulling on it or other motion the object has.  Molecules in the air produce pressure through both their weight and movement, and this pressure is connected to other properties of the atmosphere."@en ;
                                                        rdfs:label "Pressure"@en .


###  https://bimerr.iot.linkeddata.es/def/weather#Radiation
<https://bimerr.iot.linkeddata.es/def/weather#Radiation> rdf:type owl:Class ;
                                                         rdfs:subClassOf <https://bimerr.iot.linkeddata.es/def/weather#WeatherProperty> ;
                                                         rdfs:comment "The emission or transmission of energy in the form of waves or particles through space or through a material medium."@en ;
                                                         rdfs:label "Radiation"@en .


###  https://bimerr.iot.linkeddata.es/def/weather#SkyCover
<https://bimerr.iot.linkeddata.es/def/weather#SkyCover> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://bimerr.iot.linkeddata.es/def/weather#WeatherProperty> ;
                                                        rdfs:comment "The extent to which the sky is obscured by clouds."@en ;
                                                        rdfs:label "Sky Cover"@en .


###  https://bimerr.iot.linkeddata.es/def/weather#Snow
<https://bimerr.iot.linkeddata.es/def/weather#Snow> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://bimerr.iot.linkeddata.es/def/weather#Precipitation> ;
                                                    rdfs:comment "Individual ice crystals that grow while suspended in the atmosphereâ€”usually within cloudsâ€”and then fall, accumulating on the ground where they undergo further changes."@en ;
                                                    rdfs:label "Snow"@en .


###  https://bimerr.iot.linkeddata.es/def/weather#Temperature
<https://bimerr.iot.linkeddata.es/def/weather#Temperature> rdf:type owl:Class ;
                                                           rdfs:subClassOf <https://bimerr.iot.linkeddata.es/def/weather#WeatherProperty> ;
                                                           rdfs:comment "The measure of thermal or internal energy of the molecules within an object or gas.    We can measure temperature of an object using either direct contact or remote sensing.  Temperature of air is closely related to other atmospheric properties, such as pressure, volume and density."@en ;
                                                           rdfs:label "Temperature"@en .


###  https://bimerr.iot.linkeddata.es/def/weather#WeatherProperty
<https://bimerr.iot.linkeddata.es/def/weather#WeatherProperty> rdf:type owl:Class ;
                                                               rdfs:subClassOf core:Property ;
                                                               rdfs:comment "Property type to classify  weather data."@en ;
                                                               rdfs:label "Weather Property"@en .


