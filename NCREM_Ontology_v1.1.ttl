<https://w3id.org/seas/ElectricVehicleChargingStationPool> rdf:type owl:Class ;
                                                           rdfs:subClassOf brick:Electrical_Equipment ;
                                                           skos:definition "The class of electric vehicle charging station pools. An electric vehicle charging station pool is connected to the grid and composed of one or more electric vehicle charging stations." .


#################################################################
#    Additional v1.1 Classes
#################################################################

###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#MobilityStation
ncrem:MobilityStation rdf:type owl:Class ;
                      rdfs:subClassOf brick:Location ;
                      rdfs:label "Mobility Station"@en ;
                      skos:definition "A physical station or hub used by a mobility service, such as a bike-share dock, EV charging point cluster, or transit interchange."@en .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#ParkingFacility
ncrem:ParkingFacility rdf:type owl:Class ;
                      rdfs:subClassOf brick:Location ;
                      rdfs:label "Parking Facility"@en ;
                      skos:definition "A facility that groups parking spaces and related occupancy information for vehicles or bicycles."@en .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#ParkingSpace
ncrem:ParkingSpace rdf:type owl:Class ;
                   rdfs:subClassOf brick:Location ;
                   rdfs:label "Parking Space"@en ;
                   skos:definition "An individual parking space contained within a parking facility."@en .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#PedestrianFeature
ncrem:PedestrianFeature rdf:type owl:Class ;
                        rdfs:subClassOf brick:Location ;
                        rdfs:label "Pedestrian Feature"@en ;
                        skos:definition "A pedestrian-oriented urban element such as a path, crosswalk, or walkway."@en .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#PublicTransportRoute
ncrem:PublicTransportRoute rdf:type owl:Class ;
                           rdfs:label "Public Transport Route"@en ;
                           skos:definition "A route followed by a public transport service."@en .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#RoadSegment
ncrem:RoadSegment rdf:type owl:Class ;
                  rdfs:subClassOf ncrem:Street ;
                  rdfs:label "Road Segment"@en ;
                  skos:definition "A delimited segment of a street or road used for localized traffic observations and indicators."@en .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#SharedMobilityService
ncrem:SharedMobilityService rdf:type owl:Class ;
                            rdfs:label "Shared Mobility Service"@en ;
                            skos:definition "A mobility service that operates through one or more stations, vehicles, or hubs shared among users."@en .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#Street
ncrem:Street rdf:type owl:Class ;
             rdfs:subClassOf brick:Location ;
             rdfs:label "Street"@en ;
             skos:definition "A street-level urban location used to anchor pedestrian and traffic-related entities."@en .


###  http://www.semanticweb.org/filippos/ontologies/2023/4/NCREM_Ontology#TransitStop
ncrem:TransitStop rdf:type owl:Class ;
                  rdfs:subClassOf ncrem:MobilityStation ;
                  rdfs:label "Transit Stop"@en ;
                  skos:definition "A stop or station served by a public transport route."@en .


#################################################################
#    Additional v1.1 Axioms
#################################################################

ncrem:hasAgent rdfs:domain ncrem:Workflow ;
               rdfs:label "has agent"@en .


ncrem:hasDependency rdfs:domain ncrem:Task ;
                    rdfs:range ncrem:Task ;
                    rdfs:label "has dependency"@en .


ncrem:hasDuration rdfs:domain ncrem:Workflow ;
                  rdfs:range ncrem:Duration ;
                  rdfs:label "has duration"@en .


ncrem:hasImage rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( brick:Location kpi:Scenario ncrem:Workflow mat:Material )
                           ] ;
               rdfs:range ncrem:Image ;
               rdfs:label "has image"@en .


ncrem:hasLayer rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( building:BuildingElement mat:Material )
                           ] ;
               rdfs:range mat:MaterialLayer ;
               rdfs:label "has layer"@en .


ncrem:hasParkingSpace rdfs:domain ncrem:ParkingFacility ;
                      rdfs:range ncrem:ParkingSpace ;
                      rdfs:label "has parking space"@en .


ncrem:hasSensor rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( ssn:System brick:Location )
                            ] ;
                rdfs:label "has sensor"@en .


ncrem:hasSetpoint rdfs:domain ssn:System ;
                  rdfs:label "has setpoint"@en .


ncrem:hasStation rdfs:domain ncrem:SharedMobilityService ;
                 rdfs:range ncrem:MobilityStation ;
                 rdfs:label "has station"@en .


ncrem:hasSupplier rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( mat:Material ncrem:Supplier_Sourcing )
                              ] ;
                  rdfs:range ncrem:Supplier ;
                  rdfs:label "has supplier"@en ;
                  skos:definition "Relates a material or sourcing record to the supplier responsible for providing it."@en .


ncrem:hasWeatherFileProperty rdfs:domain weat:DataSourceFiles ;
                             rdfs:label "has weather file property"@en .


ncrem:locatedOnStreet rdfs:domain ncrem:PedestrianFeature ;
                      rdfs:range ncrem:Street ;
                      rdfs:label "located on street"@en .


ncrem:monitors_Segment rdfs:range ncrem:RoadSegment ;
                       rdfs:label "monitors segment"@en .


ncrem:servesStop rdfs:domain ncrem:PublicTransportRoute ;
                 rdfs:range ncrem:TransitStop ;
                 rdfs:label "serves stop"@en .


ncrem:availableSpaces rdfs:domain ncrem:ParkingFacility ;
                      rdfs:label "available spaces"@en .


ncrem:averageSpeed rdfs:domain ncrem:RoadSegment ;
                   rdfs:label "average speed"@en .


ncrem:capacity rdfs:domain ncrem:ParkingFacility ;
               rdfs:label "capacity"@en .


ncrem:congestionLevel rdfs:domain ncrem:RoadSegment ;
                      rdfs:label "congestion level"@en .


ncrem:hasBikeCapacity rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( ncrem:ParkingFacility ncrem:MobilityStation )
                                  ] ;
                      rdfs:range xsd:int ;
                      rdfs:label "has bike capacity"@en .


ncrem:occupancyRate rdfs:domain ncrem:ParkingFacility ;
                    rdfs:label "occupancy rate"@en .


ncrem:occupiedSpaces rdfs:domain ncrem:ParkingFacility ;
                     rdfs:label "occupied spaces"@en .


ncrem:vehicleCount rdfs:domain ncrem:RoadSegment ;
                   rdfs:label "vehicle count"@en .


ncrem:Indoor owl:disjointWith ncrem:Outdoor .
ncrem:Imported_Energy owl:disjointWith ncrem:Exported_Energy .
ncrem:Charged_Energy owl:disjointWith ncrem:Discharged_Energy .
ncrem:ParkingFacility owl:disjointWith ncrem:ParkingSpace .
ncrem:PublicTransportRoute owl:disjointWith ncrem:TransitStop .

#################################################################
#    Annotations
#################################################################

brick:hasUnit skos:definition "Links a measurable quantity, parameter, or setpoint to its corresponding unit of measurement" .


brick:isPointOf skos:definition "The subject is a source of telemetry related to the object. In some systems the source of telemetry may be represented as a digital/analog input/output point" .


core:hasProperty skos:definition "Links a feature kind or a feature of interest to one of its properties." .


s4city:hasKPI skos:definition "Indicates that a given feature of interest is associated with one or more Key Performance Indicators." .


saref4ener:hasEnergy skos:definition "A relationship between a power sequence and its energy (in terms of value and unit of measure)" .


